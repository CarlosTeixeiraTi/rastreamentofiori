<mvc:View
    controllerName="br.com.smartpcm.rastreamento.zrastreio.controller.Rastreamento"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">

    <Page
        id="dashboardPage"
        title="Dashboard de Rastreamento RFID">

        <content>

            <VBox
                id="mainContainer"
                class="sapUiSmallMargin">

                <!-- KPI -->



                <HBox
                    width="100%"
                    justifyContent="Center"
                    wrap="Wrap"
                    class="sapUiMediumMarginBottom">

                    <Panel
                        width="350px"
                        class="sapUiSmallMargin">

                        <VBox
                            alignItems="Center"
                            class="sapUiSmallMargin">

                            <Title
                                text="{dashboard>/totalEquipamentos}"
                                level="H1"
                                class="kpiNumero" />

                            <Text
                                text="Equipamentos"
                                class="kpiTexto" />

                        </VBox>

                    </Panel>

                    <Panel
                        width="350px"
                        class="sapUiSmallMargin">

                        <VBox
                            alignItems="Center"
                            class="sapUiSmallMargin">

                            <Title
    text="{dashboard>/online}"
    level="H1"
    class="kpiNumero" />

<Text
    text="Online"
    class="kpiTexto" />

                        </VBox>

                    </Panel>

                    <Panel
                        width="350px"
                        class="sapUiSmallMargin">

                        <VBox
                            alignItems="Center"
                            class="sapUiSmallMargin">

                            <Title
    text="{dashboard>/offline}"
    level="H1"
    class="kpiNumero" />

<Text
    text="Offline"
    class="kpiTexto" />

                        </VBox>

                    </Panel>

                    <Panel
                        width="350px"
                        class="sapUiSmallMargin">

                        <VBox
                            alignItems="Center"
                            class="sapUiSmallMargin">

                            <Title
    text="{dashboard>/gateways}"
    level="H1"
    class="kpiNumero" />

<Text
    text="Gateways"
    class="kpiTexto" />

                        </VBox>

                    </Panel>

                </HBox>

                <!-- GRUPOS + MAPA -->

                <HBox
                    width="100%"
                    fitContainer="true"
                    alignItems="Start"
                    renderType="Bare">

                    <Panel
    width="320px"
    class="sapUiSmallMarginEnd painelGrupos"
    headerText="Equipamentos">    

                        <List
    items="{dashboard>/grupos}">

    <ObjectListItem
        type="Active"
        press=".onQuantidadeObjectListItemPress"
        title="{dashboard>grupo}"
        number="{dashboard>quantidade}"
        numberUnit="" />

</List>

                    </Panel>

                    <VBox width="100%">

                        <Panel
                            id="panelMapa"
                            width="100%"
                            headerText="">

                            <content>

                                <core:HTML
                                    id="htmlMapa"
                                    preferDOM="false" />

                            </content>

                        </Panel>

                    </VBox>

                </HBox>

            </VBox>

        </content>

    </Page>

</mvc:View>