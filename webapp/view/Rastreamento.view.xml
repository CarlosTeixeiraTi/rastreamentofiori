<mvc:View
    controllerName="br.com.smartpcm.rastreamento.zrastreio.controller.Rastreamento"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
>

    <Page
        id="dashboardPage"
        title="Dashboard de Rastreamento RFID">

        <content>

            <VBox
                id="mainContainer"
                class="sapUiLargeMargin painelPrincipal">

                <!-- KPI -->

                <HBox
                    width="100%"
                    justifyContent="Center"
                    wrap="Wrap"
                    class="sapUiMediumMarginBottom">

                    <Panel
                        width="350px"
                        class="sapUiSmallMargin kpiCard kpiTotal">

                        <VBox
                            alignItems="Center"
                            class="sapUiSmallMargin">

                            <Title
                                text="{dashboard>/totalEquipamentos}"
                                level="H1"
                                class="kpiNumero" />

                            <Text
                                text="Equipamentos"
                                class="kpiTexto" />

                        </VBox>

                    </Panel>

                    <Panel
                        width="350px"
                        class="sapUiSmallMargin kpiCard kpiOnline">

                        <VBox
                            alignItems="Center"
                            class="sapUiSmallMargin">

                            <Title
                                text="{dashboard>/online}"
                                level="H1"
                                class="kpiNumero" />

                            <Text
                                text="Online"
                                class="kpiTexto" />

                        </VBox>

                    </Panel>

                    <Panel
                        width="350px"
                        class="sapUiSmallMargin kpiCard kpiOffline">

                        <VBox
                            alignItems="Center"
                            class="sapUiSmallMargin">

                            <Title
                                text="{dashboard>/offline}"
                                level="H1"
                                class="kpiNumero" />

                            <Text
                                text="Offline"
                                class="kpiTexto" />

                        </VBox>

                    </Panel>

                    <Panel
                        width="350px"
                        class="sapUiSmallMargin kpiCard kpiGateway">

                        <VBox
                            alignItems="Center"
                            class="sapUiSmallMargin">

                            <Title
                                text="{dashboard>/gateways}"
                                level="H1"
                                class="kpiNumero" />

                            <Text
                                text="Gateways"
                                class="kpiTexto" />

                        </VBox>

                    </Panel>

                </HBox>

                <!-- GRUPOS + MAPA -->

                <HBox
                    width="100%"
                    fitContainer="true"
                    alignItems="Start"
                    justifyContent="SpaceBetween"
                    renderType="Bare">

                    <Panel
                        width="320px"
                        class="sapUiSmallMarginEnd painelGrupos"
                        headerText="Equipamentos">

                        <List
                            items="{dashboard>/grupos}">

                            <ObjectListItem
                                type="Active"
                                press=".onQuantidadeObjectListItemPress"
                                title="{dashboard>grupo}"
                                number="{dashboard>quantidade}"
                                numberUnit="" />

                        </List>

                    </Panel>

                    <VBox width="100%">

                        <SearchField
                            id="idPesquisaRastreador"
                            width="300px"
                            placeholder="Pesquisar rastreador"
                            search=".onPesquisarRastreador"
                            class="sapUiSmallMarginBottom pesquisaRastreador" />

                        <Panel
                            id="panelMapa"
                            width="100%"
                            class="painelMapa"
                            headerText="">

                            <content>

                                <core:HTML
                                    id="htmlMapa"
                                    preferDOM="false" />

                            </content>

                        </Panel>

                    </VBox>

                </HBox>

                <Panel
                    headerText="Resumo por Tipo de Equipamento"
                    class="sapUiMediumMarginTop">

                    <Table
                        items="{dashboard>/resumoEquipamentos}">

                        <columns>

                            <Column>
                                <Text text="Equipamento" />
                            </Column>

                            <Column hAlign="Center">
                                <Text text="Total" />
                            </Column>

                            <Column hAlign="Center">
                                <Text text="Instalados" />
                            </Column>

                            <Column hAlign="Center">
                                <Text text="Ref. Interna" />
                            </Column>

                            <Column hAlign="Center">
                                <Text text="Ref. Externa" />
                            </Column>

                            <Column hAlign="Center">
                                <Text text="Reformados" />
                            </Column>

                            <Column hAlign="Center">
                                <Text text="A Reformar" />
                            </Column>

                        </columns>

                        <items>

                            <ColumnListItem>

                                <cells>

                                    <Text text="{dashboard>familia}" />

                                    <ObjectNumber
                                        number="{dashboard>total}" />

                                    <ObjectNumber
                                        number="{dashboard>instalados}" />

                                    <ObjectNumber
                                        number="{dashboard>reformaInterna}" />

                                    <ObjectNumber
                                        number="{dashboard>reformaExterna}" />

                                    <ObjectNumber
                                        number="{dashboard>reformados}" />

                                    <ObjectNumber
                                        number="{dashboard>aReformar}" />

                                </cells>

                            </ColumnListItem>

                        </items>

                    </Table>

                </Panel>


                <Panel
                    headerText="Resumo por Grupo Atual"
                    class="sapUiMediumMarginTop">

                    <Table
                        items="{dashboard>/resumoGrupoAtual}">

                        <columns>
                            <Column width="15rem">
                                <Text text="Grupo Atual" />
                            </Column>

                            <Column
                                width="6rem"
                                hAlign="Begin">
                                <Text text="Quantidade" />
                            </Column>

                        </columns>

                        <items>

                            <ColumnListItem>

                                <cells>

                                    <Text
                                        text="{dashboard>grupo}" />

                                    <ObjectNumber
                                        number="{dashboard>quantidade}" />

                                </cells>

                            </ColumnListItem>

                        </items>

                    </Table>

                </Panel>
                <Panel
                    headerText="Detalhes das Tags Desatualizadas (>72h)"
                    class="sapUiMediumMarginTop">

                    <Table
                        items="{dashboard>/detalhesTagsDesatualizadas}">

                        <columns>

                            <Column width="5rem">
                                <Text text="Identificador" />
                            </Column>

                            <Column width="10rem">
                                <Text text="Equipamento" />
                            </Column>

                            <Column width="12rem">
                                <Text text="Local de Instalação" />
                            </Column>

                            <Column width="7rem">
                                <Text text="Grupo Atual" />
                            </Column>

                            <Column width="6rem">
                                <Text text="Última Atualização" />
                            </Column>
                            <Column
                                width="2rem"
                                hAlign="End">
                                <Text text="Dias" />
                            </Column>

                            <Column width="20rem">
                                <Text text="Dedução" />
                            </Column>

                        </columns>

                        <items>

                            <ColumnListItem
                                highlight="{
        = ${dashboard>grupoAtual} === 'Reformado'
            ? 'Warning'
            : 'None'
    }">

                                <cells>

                                    <Text
                                        text="{dashboard>identificador}" />

                                    <Text
                                        text="{dashboard>equipamento}" />

                                    <Text
                                        text="{dashboard>localInstalacao}" />

                                    <Text
                                        text="{dashboard>grupoAtual}" />

                                    <Text
                                        text="{dashboard>ultimaPosicao}" />

                                    <ObjectNumber
                                        number="{dashboard>diasSemAtualizacao}"
                                        textAlign="End" />

                                    <ObjectStatus
                                        text="{dashboard>deducao}"
                                        state="Information" />
                                </cells>
                            </ColumnListItem>

                        </items>

                    </Table>

                </Panel>
                <Panel
                    headerText="Conferência de Componentes Embarcados"
                    class="sapUiMediumMarginTop">

                    <Table
                        items="{dashboard>/dashboardVeiculos}">

                        <columns>

                            <Column width="7rem">
                                <Text text="Imagem" />
                            </Column>

                            <Column width="10rem">
                                <Text text="Veículo" />
                            </Column>

                            <Column width="40rem">
                                <Text text="Conferência" />
                            </Column>

                            <Column width="8rem">
                                <Text text="Status" />
                            </Column>

                        </columns>

                        <items>


                            <ColumnListItem>
                                <cells>


                                    <Image
                                        src="{dashboard>imagem}"
                                        width="" />


                                    <Text
                                        text="{dashboard>veiculo}" />

                                    <Text
                                        text="{dashboard>conferencia}" />

                                    <ObjectStatus
                                        text="{dashboard>status}"
                                        state="{dashboard>state}" />


                                </cells>


                            </ColumnListItem>


                        </items>

                    </Table>

                </Panel>
                <Panel
                    headerText="Resumo por Fornecedor e Frota"
                    class="sapUiMediumMarginTop">

                    <Table
                        items="{dashboard>/resumoFrotas}">

                        <columns>

                            <Column width="8rem">
                                <Text text="Imagem" />
                            </Column>

                            <Column width="10rem">
                                <Text text="Fornecedor" />
                            </Column>

                            <Column width="6rem">
                                <Text text="Frota" />
                            </Column>

                            <Column hAlign="Center">
                                <Text text="Comando Final" />
                            </Column>

                            <Column hAlign="Center">
                                <Text text="Transmissão" />
                            </Column>

                            <Column hAlign="Center">
                                <Text text="Conversor de Torque" />
                            </Column>

                            <Column hAlign="Center">
                                <Text text="Diferencial" />
                            </Column>

                            <Column hAlign="Center">
                                <Text text="Motor" />
                            </Column>

                            <Column hAlign="Center">
                                <Text text="Total" />
                            </Column>

                        </columns>

                        <items>
                            <ColumnListItem
                                highlight="{=
        ${dashboard>fornecedor} === 'TOTAL'
            ? 'Warning'
            : 'None'
    }">

                                <cells>
                                    <Image
                                        src="{dashboard>imagem}"
                                        width="" />
                                    <Text
                                        text="{dashboard>fornecedor}" />

                                    <Text
                                        text="{dashboard>frota}" />

                                    <ObjectNumber
                                        number="{dashboard>comandoFinal}" />

                                    <ObjectNumber
                                        number="{dashboard>transmissao}" />

                                    <ObjectNumber
                                        number="{dashboard>conversorTorque}" />

                                    <ObjectNumber
                                        number="{dashboard>diferencial}" />

                                    <ObjectNumber
                                        number="{dashboard>motor}" />

                                    <ObjectNumber
                                        number="{dashboard>total}" />

                                </cells>

                            </ColumnListItem>

                        </items>

                    </Table>

                </Panel>
                <Panel
                    headerText="Status dos Componentes por Tipo"
                    class="sapUiMediumMarginTop">

                    <viz:VizFrame
                        id="idTipoStatusVizFrame"
                        vizType="stacked_column"
                        width="100%"
                        height="500px">

                    </viz:VizFrame>

                </Panel>
                <Panel
                    headerText="Reformados por Oficina"
                    class="sapUiMediumMarginTop">

                    <viz:VizFrame
                        id="idReformadosOficinaVizFrame"
                        vizType="stacked_bar"
                        width="100%"
                        height="500px" />

                </Panel>
                <Panel
                    headerText="Instalação dos Rastreadores"
                    class="sapUiMediumMarginTop">

                    <viz:VizFrame
                        id="idInstalacaoVizFrame"
                        vizType="donut"
                        width="100%"
                        height="400px" />

                </Panel>
                <Panel>

                    
                </Panel>
            </VBox>

        </content>

    </Page>

</mvc:View>