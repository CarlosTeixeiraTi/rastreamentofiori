  {
    "_version": "1.85.0",
    "sap.app": {
      "id": "br.com.smartpcm.rastreamento.zrastreio",
      "type": "application",
      "i18n": "i18n/i18n.properties",
      "applicationVersion": {
        "version": "0.0.1"
      },
      "title": "{{appTitle}}",
      "description": "{{appDescription}}",
      "resources": "resources.json",
      "sourceTemplate": {
        "id": "@sap/generator-fiori:basic",
        "version": "1.27.0",
        "toolsId": "604d506f-d832-4acd-a130-9dceeed7c12e"
      },
      "dataSources": {
        "mainService": {
          "uri": "/odata/v4/smart-pcm/",
          "type": "OData",
          "settings": {
            "annotations": [],
            "localUri": "localService/mainService/metadata.xml",
            "odataVersion": "4.0"
          }
        }
      }
    },
    "sap.ui": {
      "technology": "UI5",
      "icons": {
        "icon": "",
        "favIcon": "",
        "phone": "",
        "phone@2": "",
        "tablet": "",
        "tablet@2": ""
      },
      "deviceTypes": {
        "desktop": true,
        "tablet": true,
        "phone": true
      }
    },
"sap.ui5": {
  "dependencies": {
    "minUI5Version": "1.149.1",
    "libs": {
  "sap.m": {},
  "sap.ui.core": {},
  "sap.ui.layout": {},
  "sap.f": {},
  "sap.ui.export": {}
}

  
      },
      "contentDensities": {
        "compact": true,
        "cozy": true
      },
      "models": {
        "i18n": {
          "type": "sap.ui.model.resource.ResourceModel",
          "settings": {
            "bundleName": "br.com.smartpcm.rastreamento.zrastreio.i18n.i18n"
          }
        },
        "": {
          "dataSource": "mainService",
          "preload": true,
          "settings": {
            "operationMode": "Server",
            "autoExpandSelect": true,
            "earlyRequests": true
          }
        }
      },
      "resources": {
        "css": [
          {
            "uri": "css/style.css"
          }
        ]
      },
      "routing": {
        "config": {
          "routerClass": "sap.m.routing.Router",
          "controlAggregation": "pages",
          "controlId": "app",
          "transition": "fade",
          "type": "View",
          "viewType": "XML",
          "path": "br.com.smartpcm.rastreamento.zrastreio.view",
          "async": true,
          "viewPath": "br.com.smartpcm.rastreamento.zrastreio.view"
        },
        "routes": [
          {
            "name": "RouteRastreamento",
            "pattern": ":?query:",
            "target": [
              "TargetRastreamento"
            ]
          }
        ],
        "targets": {
          "TargetRastreamento": {
            "id": "Rastreamento",
            "name": "Rastreamento"
          }
        }
      },
      "rootView": {
        "viewName": "br.com.smartpcm.rastreamento.zrastreio.view.App",
        "type": "XML",
        "id": "App",
        "async": true
      }
    }
  }
